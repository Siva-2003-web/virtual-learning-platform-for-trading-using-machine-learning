# Example environment variables for development
# Copy this file to .nvmrc or .env and fill values as needed.

# Secret used to sign JWT tokens. Required.
STOTRA_JWT_SECRET=your_jwt_secret_here

# Optional: Cloudflare Turnstile secret for signup validation
STOTRA_TURNSTILE_SECRET=

# MongoDB connection URI. Defaults to mongodb://localhost:27017/ if not provided.
MONGO_URI=mongodb://localhost:27017/

# ML prediction service URL. Defaults to http://localhost:5001 if not provided.
ML_SERVICE_URL=http://localhost:5001
